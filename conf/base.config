/*
 * ProSIFT -- conf/base.config
 * Default resource allocations per process. Override in profiles or
 * per-process withName blocks as needed.
 */

process {

    // Global defaults
    cpus   = 1
    memory = '4.GB'
    time   = '2.h'

    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Per-process resource overrides
    //
    // maxForks = 2 on all plotting processes: kaleido launches a Chrome instance
    // per plot call. Running 12 runs in parallel saturates Chrome on macOS and
    // causes kaleido to hang at "Waiting on all navigates". Capping at 2
    // concurrent instances per process keeps the total Chrome count manageable.
    // On the HPC cluster (separate nodes per task) this is not an issue, but
    // maxForks is harmless there.
    withName: 'PRENORM_QC' {
        maxForks = 2
    }
    withName: 'NORMALIZE' {
        maxForks = 2
    }
    withName: 'IMPUTE' {
        maxForks = 2
    }
    withName: 'MISSINGNESS_REPORT' {
        maxForks = 2
    }
    withName: 'DIFFERENTIAL_ABUNDANCE' {
        maxForks = 2
    }

}
