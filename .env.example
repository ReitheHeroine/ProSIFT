# ProSIFT API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Then source it before running the pipeline:
#   source .env && export NCBI_API_KEY DISGENET_API_KEY
#
# Or add to your PBS job script before the nextflow command.

# PubMed / NCBI E-utilities (optional, improves rate from 3/sec to 10/sec)
# Register free: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_key_here

# DisGeNET (required for gene-disease associations)
# Register free academic: https://www.disgenet.com/signup
DISGENET_API_KEY=your_disgenet_key_here
