/*
 * ProSIFT -- nextflow.config
 * Infrastructure configuration. Scientific parameters live in params.yml.
 */

// Default params (overridden at runtime via --param value)
params {
    // Input
    samplesheet         = null   // path to samplesheet.csv (one row per run)

    // Output
    outdir              = 'results'
    tracedir            = "${params.outdir}/pipeline_info"

    // Resource limits (overridden per-process in conf/base.config)
    max_cpus            = 4
    max_memory          = '16.GB'
    max_time            = '24.h'
}

// Load base resource config
includeConfig 'conf/base.config'

// Execution profiles
profiles {

    // Local execution (development/testing on macOS)
    local {
        process.executor = 'local'
    }

    // HPC cluster: mesx.sdsu.edu (Torque/PBS)
    pbs {
        process.executor   = 'pbspro'
        process.queue      = 'default'
        process.clusterOptions = '-l nodes=1:ppn=${task.cpus}'
        executor {
            queueSize      = 20
            submitRateLimit = '10/1min'
        }
    }

    // Conda environment
    // Nextflow's conda activation machinery requires conda shell hooks that
    // are not available in non-interactive subprocesses. Workaround: prepend
    // the prosift env bin to PATH via beforeScript.
    //
    // Uses 'conda info --base' to find the conda prefix dynamically, so the
    // same config works on both macOS (local) and the cluster without edits.
    // Requires: (1) conda is on PATH, (2) env named 'prosift' exists.
    // Create the env first: conda env create -f environment.yml
    conda {
        // Prepend prosift env bin to PATH, and set R_HOME + DYLD_LIBRARY_PATH
        // so that rpy2 (used by Module 04 differential_abundance.py) can locate
        // libR.dylib at runtime. Without R_HOME, rpy2 segfaults on macOS even
        // when R is on PATH.
        process.beforeScript = '''
            export PROSIFT_BASE="$(conda info --base)/envs/prosift"
            export PATH="${PROSIFT_BASE}/bin:${PATH}"
            export R_HOME="${PROSIFT_BASE}/lib/R"
            export DYLD_LIBRARY_PATH="${PROSIFT_BASE}/lib/R/lib:${DYLD_LIBRARY_PATH:-}"
        '''
    }

    // Singularity container (Phase 1+)
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

}

// Execution tracing and reporting
timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace.txt"
}
